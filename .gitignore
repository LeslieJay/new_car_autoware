# Only track src/ — ignore everything else at repo root
/*
!/.gitignore
!/.gitattributes
!/src/

# Vim
*.swp
*.swo

# Visual Studio Code
.vscode/
*.code-workspace

# colcon
build/
install/
log/

# Python
*.pyc
__pycache__/

# Jetbrains
.idea/

# rviz Screen Capture
capture/

# CodeChecker
.codechecker/

# Node.js
node_modules/

# Isaac ROS prebuilt binaries and large test assets (download/build locally)
src/sensing/isaac_ros_nitros/**/lib/
src/sensing/isaac_ros_nitros/**/*.a
**/resources/**/*.db3
**/resources/**/*.db3.zstd
**/resources/**/*.zstd
**/resources/**/*.bag
trtexec_x86_64

# BYD MQTT/CAN recorded data (keep locally, do not version)
src/byd/ROS2_DEV_MQTT-3-23/**/can_data.json
src/byd/ROS2_DEV_MQTT-3-23/**/static_data.json
src/byd/ROS2_DEV_MQTT-3-23/**/instant_data.json

# BYD RTK/CAN logs
src/byd/all_can_ws/rtk_can_ws/*_log.txt
src/byd/all_can_ws/rtk_can_ws/can_log.txt
src/byd/all_can_ws/rtk_can_ws/atti_quat_log.txt

# Perception model weights and build artifacts (download/build locally)
src/didrive_perception/**/*.pth
src/didrive_perception/**/*.trt
src/didrive_perception/**/*.onnx
src/didrive_perception/**/*.plan
src/didrive_perception/**/lib/*.so