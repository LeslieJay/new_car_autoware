<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>can_driver</name>
  <version>0.0.1</version>
  <description>A ROS 2 node for CAN communication using SocketCAN.</description>

  <maintainer email="dxy@todo.todo">dxy</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <!-- 依赖项 -->
  <depend>rclcpp</depend>
  <depend>rclcpp_action</depend>
  <depend>autoware_control_msgs</depend>
  <depend>tier4_external_api_msgs</depend>
  <depend>agv_interfaces</depend>
  <depend>autoware_vehicle_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>vda5050_interfaces</depend>
  <depend>ref_slam_interface</depend>
  <depend>autoware_system_msgs</depend>
  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>