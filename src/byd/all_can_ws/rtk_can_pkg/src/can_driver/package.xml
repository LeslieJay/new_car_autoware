<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>can_six_driver</name>
  <version>0.0.1</version>
  <description>RTK/INS CAN FD driver for Autoware: receive pose/velocity/IMU and feed Sixents RTCM.</description>

  <maintainer email="dxy@todo.todo">dxy</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>geometry_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>autoware_sensing_msgs</depend>
  <depend>tf2</depend>
  <depend>ament_index_cpp</depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
